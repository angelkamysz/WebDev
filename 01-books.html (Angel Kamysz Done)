      <section id="table">
        <h2>POV Character with the Most Chapters in Each Book</h2>
        <table>
          <thead>
            <tr>
              <th rowspan="2">POV Character</th>
              <th colspan="5">Books</th>
              <th rowspan="2">TOtal Chapter</th>
            </tr>
            <tr>
              <th>A Game of Thrones</th>
              <th>A Clash of Kings</th>
              <th>A Storm of Swords</th>
